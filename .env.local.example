# Resend API key for sending contact form emails.
# Sign up free at https://resend.com and create an API key.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address that contact form submissions are sent TO (your inbox).
CONTACT_EMAIL_TO=hello@zohaibahmed.com

# Email "from" address. While testing, you can use Resend's default:
# onboarding@resend.dev
# Once you've verified your domain in Resend, switch to e.g. hello@zohaibahmed.com.
CONTACT_EMAIL_FROM=onboarding@resend.dev
